:80 {
    # API Gateway - User Service
    handle /api/users/* {
        uri strip_prefix /api
        reverse_proxy user-service:8000
    }

    # API Gateway - Product Service
    handle /api/products/* {
        uri strip_prefix /api
        reverse_proxy product-service:8000
    }

    # API Gateway - Cart Service
    handle /api/cart/* {
        uri strip_prefix /api
        reverse_proxy cart-service:8000
    }

    # API Gateway - Order Service
    handle /api/orders/* {
        uri strip_prefix /api
        reverse_proxy order-service:8000
    }

    # API Gateway - Payment Service
    handle /api/payments/* {
        uri strip_prefix /api
        reverse_proxy payment-service:8000
    }

    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Frontend (must be last so /api/* is routed to services first)
    handle /* {
        reverse_proxy frontend:5173
    }

    log {
        output stdout
        format json
    }
}
